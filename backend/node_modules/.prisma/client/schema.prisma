// schema.prisma

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// Update your existing enum or add this new one
enum Department {
  USHER
  VENUE_MANAGER
  PROTOCOL
  WELFARE
  CHOIR
}

enum Role {
  VOLUNTEER
  UNIT_HEAD
  ADMIN
}

// Ensure your User model uses this enum
model User {
  id            String       @id @default(uuid())
  email         String       @unique
  password      String
  fullName      String?
  phoneNumber   String?
  unilagStatus  String?
  passportPhoto String?
  department    Department? // Links to the enum above
  status        String       @default("PENDING")
  role          Role         @default(VOLUNTEER)
  qrCode        String?      @unique
  attendances   Attendance[]
}

model Attendance {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String   @unique
  scannedAt DateTime @default(now())
  scannedBy String?
}
